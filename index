// ========== TAB 5: HEATMAP ==========
function buildHeatmap() {
  const key = document.getElementById('heatmap-ind').value;
  const label = IND_LABELS[key];
  
  // Collect all values for color scaling
  let allVals = [];
  CITIES.forEach(c => DATA[c][key].forEach(v => { if(v!==null && !isNaN(v)) allVals.push(v); }));
  const minV = Math.min(...allVals), maxV = Math.max(...allVals);
  
  function heatColor(v) {
    if(v===null || isNaN(v)) return '#1e2235';
    const t = (v - minV) / (maxV - minV);
    // negative=red, middle=dark, positive=teal
    if(t < 0.5) {
      const r = Math.round(255 * (1 - t*2) * 0.8);
      return `rgba(${r},40,80,${0.3+t*0.4})`;
    } else {
      const g = Math.round(255 * (t-0.5)*2 * 0.8);
      return `rgba(30,${g+80},120,${0.3+(t-0.5)*0.4})`;
    }
  }
  
  let html = `<table class="heatmap"><thead><tr><th class="ind">Stadt</th>`;
  YEARS.forEach(y => html += `<th>${y}</th>`);
  html += '</tr></thead><tbody>';
  CITIES.forEach(c => {
    html += `<tr><td class="ind">${c}</td>`;
    DATA[c][key].forEach((v,i) => {
      const disp = v===null ? '–' : v.toFixed(1);
      html += `<td style="background:${heatColor(v)};color:#e8eaf0">${disp}</td>`;
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  document.getElementById('heatmap-container').innerHTML = html;
  
  // Interpretation
  const interps = {
    nat_saldo: 'Alle Kommunen haben dauerhaft negativen natürlichen Saldo. Brilon und Schmallenberg verschlechtern sich am stärksten. Dortmund zeigt die geringste Negativdynamik durch jüngere Altersstruktur.',
    wand_saldo: '2015/2016 Spike durch Flüchtlingszuwanderung sichtbar. Seitdem Normalisierung. Positive Salden seit 2019 in den meisten Kommunen compensieren teilweise den Sterbeüberhang.',
    bildung: 'Dortmund dominiert mit konstant hohen positiven Werten (+40 bis +58). Alle Sauerlandkommunen negativ – junges Bildungswanderungsdefizit ist der Kern der Landflucht. 2018 Datenlücke erkennbar (k.A.).',
    familie: 'Seit 2014 steigen die Familienwanderungssalden im Sauerland – Familien aus urbanen Räumen ziehen zu. Dortmund verliert Familien (negativ), die ins Umland abwandern.',
    births: 'Geburtenraten relativ stabil, leicht rückläufig. Dortmund hat höchste Geburtenrate durch jüngere Bevölkerungsstruktur. Brilon und Schmallenberg niedrigste Werte.',
    deaths: 'Sterbefälle steigen über den Beobachtungszeitraum in allen Kommunen – Alterungseffekt. Brilon und Arnsberg bereits bei 13,2 je 1.000 (2023).',
    median_age: 'Kontinuierlicher Anstieg in allen Kommunen außer Dortmund (das sich stabilisiert). Brilon erreicht 47,8 Jahre – unter den ältesten Kommunen in NRW.',
    altenq: 'Altenquotienten steigen überall. Dortmund kann durch Bildungszuzug gegensteuern (stabil ~34). Brilon und Arnsberg stark steigende Abhängigkeitsquotienten.'
  };
  document.getElementById('heatmap-interpretation').textContent = interps[key] || '';
}

// ========== TAB NAVIGATION ==========
function showTab(name) {
  document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  event.target.classList.add('active');
  
  if (name === 'trends') updateTrendCharts();
  if (name === 'wanderung') updateWandCharts();
  if (name === 'alter') buildAlterCharts();
  if (name === 'heatmap') buildHeatmap();
}

