// ========== TAB 2: TRENDS ==========
let selectedTrendCities = new Set(CITIES);
let trendCharts = {};

function buildTrendControls() {
  const wrap = document.getElementById('trend-city-checks');
  wrap.innerHTML = CITIES.map(c => `
    <label class="city-cb">
      <input type="checkbox" value="${c}" checked onchange="toggleTrendCity('${c}')">
      <span style="color:${COLORS[c]}">${c}</span>
    </label>`).join('');
}

function toggleTrendCity(city) {
  if (selectedTrendCities.has(city)) selectedTrendCities.delete(city);
  else selectedTrendCities.add(city);
  updateTrendCharts();
}

function updateTrendCharts() {
  const f = parseInt(document.getElementById('slider-from').value);
  const t = parseInt(document.getElementById('slider-to').value);
  const from = Math.min(f, t), to = Math.max(f, t);
  document.getElementById('year-range-display').textContent = YEARS[from] + ' – ' + YEARS[to];
  const labels = slicedYears(from, to);
  const activeCities = CITIES.filter(c => selectedTrendCities.has(c));
  
  // Index pop chart
  const popDs = activeCities.map(c => {
    // find 2011 value
    const base = DATA[c].pop[5] || 1; // index 5 = 2011
    const vals = DATA[c].pop.slice(from, to+1).map(v => v === null ? NaN : Math.round(v/base*1000)/10);
    return { label: c, data: vals, borderColor: COLORS[c], backgroundColor: 'transparent', tension: 0.3, pointRadius: 2, borderWidth: 2 };
  });
  makeChart('chart-pop-index', {
    type: 'line', data: { labels, datasets: popDs },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: '#8892b0', boxWidth: 12 } } },
      scales: { y: { grid: { color: '#1e2235' }, title: { display:true, text: 'Index (2011=100)', color:'#8892b0' } }, x: { grid: { color: '#1e2235' } } } }
  });

  // Nat saldo
  const nsDs = activeCities.map(c => ({
    label: c, data: cityDataset(c, 'nat_saldo', from, to),
    borderColor: COLORS[c], backgroundColor: 'transparent', tension: 0.3, pointRadius: 2, borderWidth: 2
  }));
  makeChart('chart-natsaldo-trend', {
    type: 'line', data: { labels, datasets: nsDs },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: '#8892b0', boxWidth: 12 } } },
      scales: { y: { grid: { color: '#1e2235' } }, x: { grid: { color: '#1e2235' } } } }
  });

  // Wand saldo
  const wsDs = activeCities.map(c => ({
    label: c, data: cityDataset(c, 'wand_saldo', from, to),
    borderColor: COLORS[c], backgroundColor: 'transparent', tension: 0.3, pointRadius: 2, borderWidth: 2
  }));
  makeChart('chart-wand-trend', {
    type: 'line', data: { labels, datasets: wsDs },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: '#8892b0', boxWidth: 12 } } },
      scales: { y: { grid: { color: '#1e2235' } }, x: { grid: { color: '#1e2235' } } } }
  });
}

