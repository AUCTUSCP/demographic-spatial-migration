// Chart defaults
Chart.defaults.color = '#8892b0';
Chart.defaults.borderColor = '#1e2235';
Chart.defaults.font.family = 'Inter, -apple-system, sans-serif';
Chart.defaults.font.size = 11;

function makeChart(id, config) {
  const ctx = document.getElementById(id);
  if (!ctx) return null;
  if (ctx._chart) ctx._chart.destroy();
  const c = new Chart(ctx, config);
  ctx._chart = c;
  return c;
}

function cityDataset(city, key, fromIdx, toIdx) {
  const raw = DATA[city][key] || [];
  const slice = raw.slice(fromIdx, toIdx+1);
  return slice.map(v => v === null ? NaN : v);
}

function slicedYears(f, t) { return YEARS.slice(f, t+1); }

